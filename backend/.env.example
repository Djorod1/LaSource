# Copiez ce fichier en ".env" — la configuration par défaut fonctionne
# sans rien modifier (SQLite local, aucun serveur à installer).

# Clé de chiffrement des sessions et CSRF (CHANGEZ-LA EN PRODUCTION)
SECRET_KEY=remplacez-par-une-chaine-aleatoire-longue

# ─── Backend de base de données ───────────────────────────────────────
# sqlite (par défaut) -> fichier local lasource.db, aucune installation
# mysql               -> serveur MySQL (variables DB_* ci-dessous requises)
DB_TYPE=sqlite

# Chemin du fichier SQLite (DB_TYPE=sqlite uniquement)
# DB_PATH=/chemin/absolu/vers/lasource.db

# Configuration MySQL (DB_TYPE=mysql uniquement)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=lasource

# ─── Sessions ─────────────────────────────────────────────────────────
DUREE_SESSION_JOURS=14

# ─── Vérification d'adresse e-mail ────────────────────────────────────
# 1 = obligatoire (l'utilisateur doit cliquer le lien reçu par mail
#     avant de pouvoir se connecter — recommandé en production)
# 0 = optionnelle (le compte est utilisable immédiatement, le mail
#     part quand même mais la connexion n'est pas bloquée)
VERIFICATION_EMAIL_OBLIGATOIRE=0

# Mode d'envoi des e-mails
#   console = log dans la sortie du serveur (utile en dev)
#   smtp    = à implémenter (Mailgun, SendGrid, etc.)
EMAIL_MODE=console

# ─── OAuth Google (optionnel) ─────────────────────────────────────────
# Procédure :
#   1. Allez sur https://console.cloud.google.com/
#   2. Créez un projet, activez "Google+ API" (ou utilisez OAuth 2.0).
#   3. Identifiants -> Créer un ID client OAuth 2.0
#      Type d'application : Application Web
#      Origines JavaScript autorisées :
#         http://localhost:5000 (dev) + votre domaine production
#      URI de redirection : aucune nécessaire (Google Identity Services)
#   4. Copiez le Client ID ci-dessous.
GOOGLE_CLIENT_ID=

# ─── OAuth LinkedIn (optionnel) ───────────────────────────────────────
# Procédure :
#   1. Allez sur https://www.linkedin.com/developers/apps
#   2. Créez une "App", activez "Sign In with LinkedIn using OpenID Connect"
#   3. Dans "Auth" -> URLs de redirection OAuth 2.0 autorisées :
#      http://localhost:5000/api/auth/linkedin/callback (dev)
#      https://votredomaine.com/api/auth/linkedin/callback (prod)
#   4. Copiez Client ID, Client Secret et reportez ci-dessous.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback
